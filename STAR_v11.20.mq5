double   g_workingSE_RSI_OS   = 30.0;  // * FIX#421: SmartExit RSI OS threshold (default 30)
double   g_workingSE_PeakTh1  = 0.65;  // * FIX#421: Peak trail ratio peak<1.5R  (default 0.65)
double   g_workingSE_PeakTh2  = 0.72;  // * FIX#421: Peak trail ratio peak<2.5R  (default 0.72)
