        c.score_cap[2]= 95;   // H1 high scores more valid; liquidity traps ≥95

        c.se_minrr[2]      = 0.45;  // H1: SE fires when 3+ cats + RR>=0.45R. Avg loss peak=0.72R → catches all near-misses
        c.se_override_rr[2]= 0.85;  // 2 cats ≥0.85R → close (captures 0.97R peak)

