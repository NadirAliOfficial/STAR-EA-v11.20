// VSA Pattern Types
enum ENUM_VSA_PATTERN
{
    VSA_NONE = 0,              // No Pattern
    VSA_UPTHRUST = 1,          // Upthrust (Bearish)
    VSA_NO_DEMAND = 2,         // No Demand (Bearish)
    VSA_NO_SUPPLY = 3,         // No Supply (Bullish)
    VSA_STOPPING_VOLUME = 4,   // Stopping Volume
    VSA_CLIMAX = 5,            // Climax
    VSA_TEST = 6,              // Test
    VSA_SPRING = 7,            // Spring (Bullish)
    VSA_UPTHRUST_SPRING = 8,   // Upthrust after Spring
    VSA_EFFORT_NO_RESULT = 9,  // Effort with No Result
